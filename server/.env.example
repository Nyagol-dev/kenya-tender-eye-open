# Server
PORT=5000
CLIENT_URL=http://localhost:8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kenya_tender_eye
DB_USER=postgres
DB_PASSWORD=

# JWT (access token — short-lived, returned in JSON body)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m

# Refresh Token (long-lived, stored as HttpOnly cookie)
# Use a DIFFERENT secret from JWT_SECRET for defence-in-depth
REFRESH_TOKEN_SECRET=change-me-to-different-long-random-string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
NODE_ENV=development
LOG_LEVEL=info

# Admin JWT (completely separate secret from regular users)
ADMIN_JWT_SECRET=change-me-admin-long-random-string
ADMIN_TOKEN_EXPIRES_IN=8h
